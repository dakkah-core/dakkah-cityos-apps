modules = ["nodejs-24", "javascript"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "apps/web-platform: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "services/bff-gateway: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "apps/mobile: expo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "apps/mobile-driver: expo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "apps/mobile-merchant: expo"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "apps/mobile-pos: expo"

[[workflows.workflow]]
name = "apps/web-platform: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/web-platform/ pnpm --filter @cityos/web-platform run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "services/bff-gateway: API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @cityos/bff-gateway run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "apps/mobile: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @cityos/mobile run dev"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "apps/mobile-driver: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 pnpm --filter @cityos/mobile-driver run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "apps/mobile-merchant: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 pnpm --filter @cityos/mobile-merchant run dev"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "apps/mobile-pos: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3003 pnpm --filter @cityos/mobile-pos run dev"
waitForPort = 3003

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
